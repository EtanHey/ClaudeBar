{
  "_note": "Copy to .mcp.json and fill in secrets. .mcp.json is gitignored.",
  "_updated": "2026-04-18",
  "mcpServers": {
    "brainlayer": {
      "command": "socat",
      "args": ["STDIO", "UNIX-CONNECT:/tmp/brainbar.sock"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "exa": {
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "YOUR_EXA_API_KEY_HERE"
      }
    },
    "cmux": {
      "command": "bun",
      "args": ["run", "/Users/etanheyman/Gits/cmuxlayer/src/index.ts"]
    }
  }
}
